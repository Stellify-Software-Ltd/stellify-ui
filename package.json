{
  "name": "@stellisoft/stellify-ui",
  "version": "0.1.3",
  "description": "Web Component primitives and design tokens for Stellify-rendered apps",
  "type": "module",
  "main": "./dist/stellify-ui.js",
  "module": "./dist/stellify-ui.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/stellify-ui.js"
    },
    "./tokens/base.css": "./dist/tokens/base.css",
    "./tokens/shadcn.css": "./dist/tokens/themes/shadcn.css",
    "./tokens/editorial.css": "./dist/tokens/themes/editorial.css",
    "./tokens/neutral.css": "./dist/tokens/themes/neutral.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsx esbuild.config.ts",
    "dev": "tsx esbuild.config.ts --watch",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "stellify",
    "web-components",
    "design-system",
    "html-web-components"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "esbuild": "^0.21.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0"
  }
}
